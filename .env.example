# Development database (PostgreSQL via docker compose)
DATABASE_URL="postgresql://montesina:montesina@localhost:5432/montesina?schema=public"

# NextAuth
NEXTAUTH_SECRET="cambia-esto-en-produccion"
NEXTAUTH_URL="http://localhost:3000"

# Push Notifications (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu@club.es"

# Production overrides (used by docker-compose.prod.yml)
POSTGRES_DB="montesina"
POSTGRES_USER="montesina"
POSTGRES_PASSWORD=""
