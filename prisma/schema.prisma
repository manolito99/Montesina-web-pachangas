generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth tables ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Users ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  gender        Gender    @default(MALE)
  level         Int       @default(3)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  createdPachangas Pachanga[]     @relation("organizer")
  participations   Participation[]
  chatMessages     ChatMessage[]
  createdCourts    Court[]        @relation("courtCreator")

  @@map("users")
}

enum Gender {
  MALE
  FEMALE
}

// ─── Pachangas ───────────────────────────────────────────

model Pachanga {
  id        String         @id @default(cuid())
  category  Category
  date      DateTime
  duration  Int            @default(90)
  courtId   String         @map("court_id")
  court     Court          @relation(fields: [courtId], references: [id])
  levelMin  Int            @default(1) @map("level_min")
  levelMax  Int            @default(5) @map("level_max")
  maxPlayers Int           @default(4) @map("max_players")
  price     Decimal        @default(0) @db.Decimal(6, 2)
  notes     String?
  status    PachangaStatus @default(OPEN)

  organizerId String       @map("organizer_id")
  organizer   User         @relation("organizer", fields: [organizerId], references: [id])

  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  participations Participation[]
  chatMessages   ChatMessage[]

  @@map("pachangas")
}

enum Category {
  M
  F
  X
}

enum PachangaStatus {
  OPEN
  FULL
  CANCELLED
  FINISHED
}

// ─── Participations ──────────────────────────────────────

model Participation {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  user       User                @relation(fields: [userId], references: [id])
  pachangaId String              @map("pachanga_id")
  pachanga   Pachanga            @relation(fields: [pachangaId], references: [id])
  status     ParticipationStatus @default(CONFIRMED)
  position   Int?
  joinedAt   DateTime            @default(now()) @map("joined_at")

  @@unique([userId, pachangaId])
  @@map("participations")
}

enum ParticipationStatus {
  CONFIRMED
  WAITLIST
  CANCELLED
}

// ─── Courts ──────────────────────────────────────────────

model Court {
  id        String    @id @default(cuid())
  name      String
  type      CourtType
  location  String?
  address   String?
  isClub    Boolean   @default(false) @map("is_club")
  createdBy String?   @map("created_by")
  creator   User?     @relation("courtCreator", fields: [createdBy], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  pachangas Pachanga[]

  @@map("courts")
}

enum CourtType {
  INDOOR
  OUTDOOR
}

// ─── Chat ────────────────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  text       String
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  pachangaId String   @map("pachanga_id")
  pachanga   Pachanga @relation(fields: [pachangaId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}
