generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth tables ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Users ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  gender           Gender    @default(MALE)
  level            Int       @default(3)
  profileCompleted Boolean   @default(false) @map("profile_completed")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  createdPachangas Pachanga[]     @relation("organizer")
  participations   Participation[]
  chatMessages     ChatMessage[]
  createdCourts        Court[]              @relation("courtCreator")
  notifPrefs           NotificationPrefs?
  pushSubs             PushSubscription[]
  createdTournaments   Tournament[]         @relation("tournamentOrganizer")
  tournamentPlayers    TournamentPlayer[]

  @@map("users")
}

enum Gender {
  MALE
  FEMALE
}

// ─── Pachangas ───────────────────────────────────────────

model Pachanga {
  id        String         @id @default(cuid())
  category  Category
  date      DateTime
  duration  Int            @default(90)
  courtId   String         @map("court_id")
  court     Court          @relation(fields: [courtId], references: [id])
  levelMin  Int            @default(1) @map("level_min")
  levelMax  Int            @default(5) @map("level_max")
  maxPlayers Int           @default(4) @map("max_players")
  price     Decimal        @default(0) @db.Decimal(6, 2)
  notes     String?
  status    PachangaStatus @default(OPEN)

  organizerId String       @map("organizer_id")
  organizer   User         @relation("organizer", fields: [organizerId], references: [id])

  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  participations Participation[]
  chatMessages   ChatMessage[]

  @@map("pachangas")
}

enum Category {
  M
  F
  X
}

enum PachangaStatus {
  OPEN
  FULL
  CANCELLED
  FINISHED
}

// ─── Participations ──────────────────────────────────────

model Participation {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  user       User                @relation(fields: [userId], references: [id])
  pachangaId String              @map("pachanga_id")
  pachanga   Pachanga            @relation(fields: [pachangaId], references: [id])
  status         ParticipationStatus @default(CONFIRMED)
  position       Int?
  joinedAt       DateTime            @default(now()) @map("joined_at")
  reminderSentAt DateTime?           @map("reminder_sent_at")

  @@unique([userId, pachangaId])
  @@map("participations")
}

enum ParticipationStatus {
  CONFIRMED
  WAITLIST
  CANCELLED
}

// ─── Courts ──────────────────────────────────────────────

model Court {
  id        String    @id @default(cuid())
  name      String
  type      CourtType
  location  String?
  address   String?
  isClub    Boolean   @default(false) @map("is_club")
  createdBy String?   @map("created_by")
  creator   User?     @relation("courtCreator", fields: [createdBy], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  pachangas  Pachanga[]
  notifPrefs NotificationPrefs[]

  @@map("courts")
}

enum CourtType {
  INDOOR
  OUTDOOR
}

// ─── Chat ────────────────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  text       String
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  pachangaId String   @map("pachanga_id")
  pachanga   Pachanga @relation(fields: [pachangaId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}

// ─── Notification Preferences ────────────────────────────

model NotificationPrefs {
  id              String  @id @default(cuid())
  userId          String  @unique @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  newPachanga     Boolean @default(true) @map("new_pachanga")
  onlyMyLevel     Boolean @default(true) @map("only_my_level")
  catMasculino    Boolean @default(true) @map("cat_masculino")
  catFemenino     Boolean @default(true) @map("cat_femenino")
  catMixto        Boolean @default(true) @map("cat_mixto")
  plazaLibre      Boolean @default(false) @map("plaza_libre")
  recordatorio    Boolean @default(true)
  minutesBefore   Int     @default(60) @map("minutes_before")
  alguienSeApunta Boolean @default(true) @map("alguien_se_apunta")
  courtId         String? @map("court_id")
  court           Court?  @relation(fields: [courtId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_prefs")
}

// ─── Push Subscriptions ──────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}

// ─── Tournaments ────────────────────────────────────────

enum TournamentFormat {
  AMERICANO
  MEXICANO
  PERSONALIZADO
}

enum TournamentStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  FINISHED
}

model Tournament {
  id             String           @id @default(cuid())
  name           String
  format         TournamentFormat
  category       Category
  status         TournamentStatus @default(DRAFT)
  pointsPerMatch Int              @default(21) @map("points_per_match")
  freeScoring    Boolean          @default(false) @map("free_scoring")
  matchDurationMin Int?           @map("match_duration_min")
  courtIds       String[]         @map("court_ids")
  notes          String?

  organizerId    String           @map("organizer_id")
  organizer      User             @relation("tournamentOrganizer", fields: [organizerId], references: [id])

  currentRound   Int              @default(0) @map("current_round")

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  players        TournamentPlayer[]
  rounds         TournamentRound[]

  @@map("tournaments")
}

model TournamentPlayer {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String?    @map("user_id")
  user         User?      @relation(fields: [userId], references: [id])
  guestName    String?    @map("guest_name")
  guestLevel   Int?       @map("guest_level")
  totalPoints  Int        @default(0) @map("total_points")
  active       Boolean    @default(true)
  joinedAt     DateTime   @default(now()) @map("joined_at")

  matchesAsP1  TournamentMatch[] @relation("matchP1")
  matchesAsP2  TournamentMatch[] @relation("matchP2")
  matchesAsP3  TournamentMatch[] @relation("matchP3")
  matchesAsP4  TournamentMatch[] @relation("matchP4")

  @@map("tournament_players")
}

model TournamentRound {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundNumber  Int        @map("round_number")
  createdAt    DateTime   @default(now()) @map("created_at")

  matches      TournamentMatch[]

  @@unique([tournamentId, roundNumber])
  @@map("tournament_rounds")
}

model TournamentMatch {
  id         String          @id @default(cuid())
  roundId    String          @map("round_id")
  round      TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  courtIndex Int             @default(0) @map("court_index")

  player1Id  String          @map("player1_id")
  player1    TournamentPlayer @relation("matchP1", fields: [player1Id], references: [id])
  player2Id  String          @map("player2_id")
  player2    TournamentPlayer @relation("matchP2", fields: [player2Id], references: [id])
  player3Id  String          @map("player3_id")
  player3    TournamentPlayer @relation("matchP3", fields: [player3Id], references: [id])
  player4Id  String          @map("player4_id")
  player4    TournamentPlayer @relation("matchP4", fields: [player4Id], references: [id])

  scoreTeamA Int?            @map("score_team_a")
  scoreTeamB Int?            @map("score_team_b")
  completed  Boolean         @default(false)
  createdAt  DateTime        @default(now()) @map("created_at")

  @@map("tournament_matches")
}
