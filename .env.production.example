# ─── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=montesina
POSTGRES_USER=montesina
POSTGRES_PASSWORD=      # REQUIRED: openssl rand -base64 32

# ─── Database URL ───────────────────────────────────────
# Must use Docker service name "db" as hostname
DATABASE_URL=postgresql://montesina:YOUR_PASSWORD_HERE@db:5432/montesina?schema=public

# ─── NextAuth ───────────────────────────────────────────
NEXTAUTH_SECRET=        # REQUIRED: openssl rand -base64 32
NEXTAUTH_URL=https://pachangasmontesina.cc

# ─── Google OAuth ───────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# Add redirect URI: https://pachangasmontesina.cc/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Push Notifications (VAPID) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nolomanolo990@gmail.com

# ─── Cron ──────────────────────────────────────────────
# Secret for /api/cron/reminders endpoint
CRON_SECRET=              # REQUIRED: openssl rand -base64 32
